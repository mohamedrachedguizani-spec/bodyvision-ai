# ════════════════════════════════════════════════════════════
# BodyVision AI — Variables d'environnement (.env.example)
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer le fichier .env
# ════════════════════════════════════════════════════════════

# ── Base de données ───────────────────────────────────────────
# LOCAL (développement) :
DB_HOST=localhost
DB_NAME=bodyvision_ai
DB_USER=root
DB_PASSWORD=

# RAILWAY (injecté automatiquement par le plugin MySQL Railway) :
# DATABASE_URL=mysql://root:password@containers-us-west-xxx.railway.app:PORT/railway

# ── JWT — générer avec le générateur PowerShell dans DEPLOIEMENT.md ──
SECRET_KEY=CHANGE_ME_64_chars_random
REFRESH_SECRET_KEY=CHANGE_ME_64_chars_random

# ── API Keys ──────────────────────────────────────────────────
GROQ_API_KEY=gsk_VOTRE_CLE_GROQ

# ── Modèle YOLO — hébergé dans GitHub Releases ────────────────
MODEL_URL=https://github.com/mohamedrachedguizani-spec/bodyvision-ai/releases/download/v1.0.0/best.pt

# ── Application ───────────────────────────────────────────────
ENVIRONMENT=production
PORT=8000
