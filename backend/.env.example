# ═══════════════════════════════════════════════════════════════
# BodyVision AI — Variables d'environnement (.env.example)
# 
# 1. Copier ce fichier : cp .env.example .env
# 2. Remplir TOUTES les valeurs (ne jamais committer le .env !)
# ═══════════════════════════════════════════════════════════════

# ── Base de données (Railway MySQL) ─────────────────────────────
# Valeurs disponibles dans le dashboard Railway > service MySQL > Variables
DB_HOST=mysql.railway.internal
DB_NAME=railway
DB_USER=root
DB_PASSWORD=VOTRE_MOT_DE_PASSE_RAILWAY
DB_PORT=3306

# ── JWT ──────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=GENERER_UNE_CLE_SECRETE_MIN_32_CHARS
JWT_REFRESH_SECRET_KEY=GENERER_UNE_AUTRE_CLE_SECRETE_MIN_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Services IA ───────────────────────────────────────────────────
# Clé Groq : https://console.groq.com/keys
GROQ_API_KEY=VOTRE_CLE_GROQ

# ── Application ───────────────────────────────────────────────────
ENVIRONMENT=production
# PORT est injecté automatiquement par Railway (ne pas modifier)
# PORT=8000
