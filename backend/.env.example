# ════════════════════════════════════════════════════════════
# BodyVision AI — Variables d'environnement (.env.example)
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer le fichier .env
# ════════════════════════════════════════════════════════════

# ── Base de données ───────────────────────────────────────────
# LOCAL (développement) :
DB_HOST=localhost
DB_NAME=bodyvision_ai
DB_USER=root
DB_PASSWORD=

# HEROKU (injecté automatiquement par l'addon ClearDB) :
# CLEARDB_DATABASE_URL=mysql://user:password@host/database?reconnect=true

# ── JWT — générer avec : openssl rand -hex 32 ─────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
REFRESH_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── API Keys ──────────────────────────────────────────────────
GROQ_API_KEY=gsk_VOTRE_CLE_GROQ

# ── Modèle YOLO (Heroku uniquement) ───────────────────────────
# Héberger best.pt dans GitHub Releases et coller l'URL ici :
MODEL_URL=https://github.com/mohamedrachedguizani-spec/bodyvision-ai/releases/download/v1.0.0/best.pt

# ── Application ───────────────────────────────────────────────
ENVIRONMENT=production
PORT=8000
